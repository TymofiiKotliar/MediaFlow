<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MediaFlow.Presentation.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="MediaFlow.Presentation.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MediaFlow"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600">

    <Grid ColumnDefinitions="180,*">

        <!-- ── Sidebar ── -->
        <Border Grid.Column="0"
                Background="#EDECEA"
                BorderBrush="#DDDAD4"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="14,18,14,14">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <!-- Camera icon -->
                        <Border Background="#1C1C1C" CornerRadius="5"
                                Width="26" Height="26"
                                VerticalAlignment="Center">
                            <Canvas Width="16" Height="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Rectangle Canvas.Left="0" Canvas.Top="1"
                                           Width="11" Height="10"
                                           Fill="White" RadiusX="1.5" RadiusY="1.5"/>
                                <Polygon Points="11,1 16,4 16,8 11,11"
                                         Fill="White"/>
                            </Canvas>
                        </Border>
                        <TextBlock Text="MediaFlow"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="#1C1C1C"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Version -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="v1.0.0"
                           Padding="16,12"
                           Foreground="#A09D97"
                           FontSize="11"/>

                <!-- Nav items -->
                <StackPanel Margin="8,4,8,0">
                    <Border Background="#DEDAD1"
                            CornerRadius="5"
                            Padding="10,8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <!-- 2×2 grid icon -->
                            <Canvas Width="13" Height="13" VerticalAlignment="Center">
                                <Rectangle Canvas.Left="0" Canvas.Top="0"
                                           Width="5" Height="5"
                                           Fill="#3A3835" RadiusX="1" RadiusY="1"/>
                                <Rectangle Canvas.Left="7" Canvas.Top="0"
                                           Width="5" Height="5"
                                           Fill="#3A3835" RadiusX="1" RadiusY="1"/>
                                <Rectangle Canvas.Left="0" Canvas.Top="7"
                                           Width="5" Height="5"
                                           Fill="#3A3835" RadiusX="1" RadiusY="1"/>
                                <Rectangle Canvas.Left="7" Canvas.Top="7"
                                           Width="5" Height="5"
                                           Fill="#3A3835" RadiusX="1" RadiusY="1"/>
                            </Canvas>
                            <TextBlock Text="Devices"
                                       FontSize="13"
                                       Foreground="#1C1C1C"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── Content area ── -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>

    </Grid>
</Window>
