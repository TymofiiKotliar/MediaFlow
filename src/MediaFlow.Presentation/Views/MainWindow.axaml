<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MediaFlow.Presentation.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="MediaFlow.Presentation.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MediaFlow"
        Icon="avares://MediaFlow.Presentation/Assets/Icons/AppIconWindows.ico"
        WindowState="Maximized"
        MinWidth="900" MinHeight="600">

    <Grid ColumnDefinitions="180,*">

        <!-- ── Sidebar ── -->
        <Border Grid.Column="0"
                Background="#EDECEA"
                BorderBrush="#DDDAD4"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Logo -->
                <Button DockPanel.Dock="Top"
                        Command="{Binding NavigateToDeviceListCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="14,18,14,14"
                        Cursor="Hand"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Image Source="avares://MediaFlow.Presentation/Assets/Icons/in-app-icon.png"
                               Width="26" Height="26"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        <TextBlock Text="MediaFlow"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="#1C1C1C"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Version -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="v1.0.0"
                           Padding="16,12"
                           Foreground="#A09D97"
                           FontSize="11"/>

                <!-- Nav items -->
                <StackPanel Margin="8,4,8,0">
                    <Button Command="{Binding NavigateToDeviceListCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch">
                        <Border Background="#DEDAD1"
                                CornerRadius="5"
                                Padding="10,8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <!-- 2×2 grid icon -->
                                <Canvas Width="13" Height="13" VerticalAlignment="Center">
                                    <Rectangle Canvas.Left="0" Canvas.Top="0"
                                               Width="5" Height="5"
                                               Fill="#3A3835" RadiusX="1" RadiusY="1"/>
                                    <Rectangle Canvas.Left="7" Canvas.Top="0"
                                               Width="5" Height="5"
                                               Fill="#3A3835" RadiusX="1" RadiusY="1"/>
                                    <Rectangle Canvas.Left="0" Canvas.Top="7"
                                               Width="5" Height="5"
                                               Fill="#3A3835" RadiusX="1" RadiusY="1"/>
                                    <Rectangle Canvas.Left="7" Canvas.Top="7"
                                               Width="5" Height="5"
                                               Fill="#3A3835" RadiusX="1" RadiusY="1"/>
                                </Canvas>
                                <TextBlock Text="Devices"
                                           FontSize="13"
                                           Foreground="#1C1C1C"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── Content area ── -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>

    </Grid>
</Window>
